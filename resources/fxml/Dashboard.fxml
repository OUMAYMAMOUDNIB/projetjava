<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../application/application.css"
            fx:controller="controllers.DashboardController">

    <left>
        <VBox spacing="15" styleClass="sidebar">
            <padding>
                <Insets top="30" right="10" bottom="30" left="10"/>
            </padding>

            <Label text="Gestion de Pharmacie" styleClass="sidebar-title"/>
            <Button text="Statistiques" onAction="#afficherStatistiques" maxWidth="Infinity" styleClass="menu-btn"/>
            <Button text="Medicaments" onAction="#afficherMedicaments" maxWidth="Infinity" styleClass="menu-btn"/>
            <Button text="Approvisionnements" onAction="#afficherApprovisionnements" maxWidth="Infinity" styleClass="menu-btn"/>
            <Button text="Ventes" onAction="#afficherVentes" maxWidth="Infinity" styleClass="menu-btn"/>
            <Button text="Pharmaciens" onAction="#afficherPharmaciens" maxWidth="Infinity" styleClass="menu-btn"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenuPane"/>
    </center>
</BorderPane>
